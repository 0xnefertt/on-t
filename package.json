{
  "name": "on-t",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "pnpm --filter @on-t/shared build && turbo dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "globals": "^16.5.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "turbo": "^2.8.20",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.53.1"
  }
}
